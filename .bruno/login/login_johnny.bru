meta {
  name: login_johnny
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/v1/login
  body: json
  auth: none
}

body:json {
  {
    "username": "{{username}}",
    "password": "{{password}}",
    "session": {
      "user_agent": "Mozilla/5.0 (Macintosh; Intel Mac OS X x.y; rv:42.0) Gecko/20100101 Firefox/42.0",
      "ipv4_address": "192.168.1.1"
    }
  }
}

vars:pre-request {
  username: johnny
  password: password123!password
}
