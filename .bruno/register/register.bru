meta {
  name: register
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/v1/register
  body: json
  auth: none
}

body:json {
  {
    "email": "test{{timestamp}}@test.com",
    "username": "Test{{timestamp}}",
    "password": "Password123!password"
  }
}

script:pre-request {
  const timestamp = Date.now();
  bru.setVar("timestamp", timestamp);
}
